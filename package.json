{
  "name": "@transloadit/convex",
  "description": "Transloadit component for Convex",
  "version": "0.0.3",
  "type": "module",
  "packageManager": "yarn@4.5.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transloadit/convex.git"
  },
  "license": "Apache-2.0",
  "author": "Transloadit",
  "keywords": [
    "convex",
    "component",
    "transloadit",
    "upload",
    "assembly",
    "tus",
    "media"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/emit-package-json.ts",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck",
    "verify": "yarn check && yarn verify:local",
    "verify:local": "node scripts/verify.ts --mode local",
    "verify:cloud": "node scripts/verify.ts --mode cloud",
    "verify:real": "yarn verify:cloud",
    "verify:browser": "yarn verify:local",
    "verify:convex": "yarn verify:cloud",
    "example:dev": "node ./node_modules/next/dist/bin/next dev --dir example",
    "example:build": "node ./node_modules/next/dist/bin/next build --dir example",
    "example:start": "node ./node_modules/next/dist/bin/next start --dir example",
    "lint": "biome check .",
    "format": "biome format . --write",
    "check": "yarn format && yarn lint && yarn typecheck && yarn test",
    "prepack": "yarn build",
    "template:ensure": "node scripts/ensure-template.ts",
    "tunnel": "node scripts/start-webhook-tunnel.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@convex-dev/component-source": "./src/client/index.ts",
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./react": {
      "@convex-dev/component-source": "./src/react/index.tsx",
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./lib": {
      "@convex-dev/component-source": "./src/component/lib.ts",
      "types": "./dist/component/lib.d.ts",
      "default": "./dist/component/lib.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "default": "./dist/test/index.js"
    },
    "./convex.config": {
      "@convex-dev/component-source": "./src/component/convex.config.ts",
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "peerDependencies": {
    "convex": "^1.24.8",
    "react": "^18.3.1 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@transloadit/types": "^4.1.3",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.57.0",
    "@transloadit/zod": "^4.1.3",
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.0",
    "@uppy/react": "^5.1.1",
    "@uppy/tus": "^5.1.0",
    "convex": "^1.31.4",
    "convex-test": "^0.0.41",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "next": "^16.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js"
}
